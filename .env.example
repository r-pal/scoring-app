# Environment variables are ONLY needed if you want to run against a real
# PostgreSQL database. For a quick demo, you don't need this file at all —
# just run `npm run demo` (see README) and the app uses in-memory sample data.
#
# To use a real database, copy this file to .env (cp .env.example .env) and
# fill in your own values.

# PostgreSQL connection string (use the Supabase Session Pooler URL when deployed).
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Password required for admin-protected actions (sent via x-admin-password header).
ADMIN_PASSWORD="your-admin-password"

# Comma-separated list of allowed frontend origins for CORS.
ALLOWED_ORIGINS="http://localhost:5173"

# Port the API server listens on.
PORT=3000
